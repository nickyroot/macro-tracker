# Local dev: start a local Prisma Postgres server with `npx prisma dev -n macro-tracker`
# and paste the DATABASE_URL + SHADOW_DATABASE_URL it prints.
# Production (Vercel): set by the Prisma Postgres marketplace integration
# (a prisma+postgres://... URL — supported automatically).
DATABASE_URL=""
SHADOW_DATABASE_URL=""

# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=""

# Any random string. Vercel Cron sends it as `Authorization: Bearer <secret>`;
# the ingest route rejects other callers when this is set.
CRON_SECRET=""
